@model Packer_v2.Models.PackageViewModel

@Html.DropDownListFor(model => model.Ticket.IdSolution, Model.Solutions.OrderBy(o => o.TypeSolution.NmTypeSolution).ThenBy(o => o.NmSolution).Select(x => new SelectListItem
{
    Value = x.IdSolution.ToString(),
    Text = "[" + x.TypeSolution.NmTypeSolution + "] " + x.NmSolution
}), "Selecione", new { @class = "form-control", @required = "required" })

