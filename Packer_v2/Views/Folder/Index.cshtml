@model IEnumerable<Packer_v2.Models.Folder>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.NmFolder)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.DeFolder)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.NmFolder)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.DeFolder)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.IdFolder }) |
            @Html.ActionLink("Details", "Details", new { id=item.IdFolder }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.IdFolder })
        </td>
    </tr>
}

</table>
